# === Fine-tuned extraction (OpenAI) ===
# Uncomment when using the OpenAI fine-tuned parameter extractor.
# OPENAI_API_KEY=sk-xxxxx
# OPENAI_FT_MODEL=ft:gpt-4.1-mini-xxxxx

# === Optional API providers ===
# Use these for agent mode or geometry/base-LLM API mode.
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# GEMINI_API_KEY=AIzaSy-xxxxx

# === Seoul traffic data ===
# Optional. If omitted, the app falls back to local representative statistics.
# TOPIS_API_KEY=xxxxx

# === SUMO path overrides ===
# Optional. Only set these if SUMO binaries are not already on PATH.
# SUMO_BIN=/usr/local/bin/sumo
# NETCONVERT_BIN=/usr/local/bin/netconvert
# SUMO_HOME=/opt/homebrew/opt/sumo/share/sumo

# === Base LLM configuration for geometry / modification ===
# BASE_LLM_MODE=api
# BASE_LLM_CLI=gemini
# BASE_LLM_SHARED_PROVIDER=gemini
# BASE_LLM_SHARED_MODEL=gemini-2.5-flash
# BASE_LLM_SHARED_KEY=your-shared-key

# === Optional per-provider base model overrides ===
# BASE_LLM_OPENAI_MODEL=gpt-5.4
# BASE_LLM_GEMINI_MODEL=gemini-2.5-flash
# BASE_LLM_CLAUDE_MODEL=claude-sonnet-4-5
